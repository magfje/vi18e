{
  "name": "vi18e",
  "version": "0.2.0",
  "description": "A modern translation editor built with Electron and TypeScript",
  "main": "./out/main/index.cjs",
  "scripts": {
    "dev": "bun scripts/dev.mjs",
    "build": "tsdown && vite build",
    "preview": "electron .",
    "typecheck": "tsc --noEmit",
    "postinstall": "electron-builder install-app-deps",
    "dist": "bun run build && bunx electron-builder",
    "dist:win": "bun run build && bunx electron-builder --win --x64",
    "dist:mac": "bun run build && bunx electron-builder --mac",
    "dist:linux": "bun run build && bunx electron-builder --linux --x64",
    "release": "bun scripts/release.mjs"
  },
  "overrides": {
    "tinyexec": "1.0.2"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "build": {
    "appId": "com.vi18e.app",
    "productName": "vi18e",
    "afterPack": "./scripts/afterPack.mjs",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": ".",
        "filter": [
          "windows/icon.ico",
          "linux/icons/512x512.png"
        ]
      }
    ],
    "asarUnpack": [
      "**/better-sqlite3/**/*",
      "**/bindings/**/*",
      "**/file-uri-to-path/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "resources/windows/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "resources/macos/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "resources/linux/icons"
    }
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@rolldown/plugin-babel": "^0.2.1",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-virtual": "^3.13.19",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "deepl-node": "^1.24.0",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "electron-store": "^8.2.0",
    "immer": "^11.1.4",
    "lucide-react": "^0.575.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hotkeys-hook": "^5.2.4",
    "react-resizable-panels": "^4.6.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tsdown": "^0.21.2",
    "typescript": "^5.9.3",
    "uuid": "^11.0.0",
    "vite": "^8.0.0",
    "zustand": "^5.0.11"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2"
  }
}
